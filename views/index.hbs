<html>
  <head>
    <title>CSV Parser ^-^</title>
    <style>
      body {
        font-family: "Segoe UI", sans-serif;
        padding: 40px;
        background: #f9f9f9;
      }
      .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
      }
      .card {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .file-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px;
        border-bottom: 1px solid #eee;
      }
      button {
        cursor: pointer;
        background: #5c0606;
        color: white;
        border: none;
        padding: 8px 15px;
        border-radius: 5px;
      }
      button:hover {
        background: #200303;
      }
      .table-badge {
        font-size: 0.8em;
        color: #666;
        background: #e0e0e0;
        padding: 2px 6px;
        border-radius: 4px;
      }
    </style>
  </head>
  <body>
    <h1>CSV to PostgreSQL</h1>

    <div class="grid">
      <div class="card">
        <h2>📁 Files </h2>
        <div style="background: #f4f4f4; padding: 15px; margin-bottom: 20px;">
          <h3>Upload new CSV</h3>
          <form action="/upload" method="POST" enctype="multipart/form-data">
            <input type="file" name="csvFile" accept=".csv" required />
            <button type="submit">Parse to DB</button>
          </form>
        </div>
      </div>

      <div class="card">
        <h2>📊 Database Tables</h2>
        {{#each tables}}
          <div class="file-item">
            <strong>{{this.name}}</strong>
            ({{this.count}}
            rows)
            <span style="color: rgb(255, 55, 205);">[{{this.status}}]</span>
            <a href="/table/{{this.name}}"><button>View Data</button></a>

            <form action="/delete" method="POST" style="display:inline;">
              <input type="hidden" name="tableName" value="{{this.name}}" />
              <button
                type="submit"
                style="background: red; color: white;"
              >Delete</button>
            </form>
          </div>
        {{else}}
          <p>No tables in DB yet.</p>
        {{/each}}
      </div>
    </div>
  </body>
</html>