<!DOCTYPE html>
<html>
<head>
    <title>CSV Parser ^-^</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; padding: 40px; background: #f9f9f9; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
        .card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .file-item { 
            display: flex; justify-content: space-between; align-items: center;
            padding: 10px; border-bottom: 1px solid #eee; 
        }
        button { cursor: pointer; background: #28a745; color: white; border: none; padding: 8px 15px; border-radius: 5px; }
        button:hover { background: #218838; }
        .table-badge { font-size: 0.8em; color: #666; background: #e0e0e0; padding: 2px 6px; border-radius: 4px; }
    </style>
</head>
<body>
    <h1>CSV to PostgreSQL</h1>
    
    <div class="grid">
        <div class="card">
            <h2>📁 Files in /csv folder</h2>
            {{#if files.length}}
                {{#each files}}
                    <div class="file-item">
                        <span>{{this}}</span>
                        <form action="/parse" method="POST" style="margin:0;">
                            <input type="hidden" name="fileName" value="{{this}}">
                            <button type="submit">Parse to DB</button>
                        </form>
                    </div>
                {{/each}}
            {{else}}
                <p>No .csv files found in the folder.</p>
            {{/if}}
        </div>

        <div class="card">
            <h2>📊 Database Tables</h2>
            {{#each tables}}
                <div class="file-item">
                    <strong>{{this.name}}</strong>
                    <span class="table-badge">{{this.count}} rows</span>
                    <a href="/table/{{this.name}}" style="text-decoration: none;">
                        <button style="background: #007bff;">👁️ View Data</button>
                    </a>
                </div>
            {{else}}
                <p>No tables in DB yet.</p>
            {{/each}}
        </div>
    </div>
</body>
</html>