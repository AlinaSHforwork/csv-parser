<div style="padding: 20px;">
    <a href="/">&larr; Back to Dashboard</a>
    <h1>Data for Table: <span style="color: #007bff;">{{tableName}}</span></h1>
    <form method="GET" action="/table/{{tableName}}" style="margin-bottom: 20px;">
        <input type="text" name="search" value="{{search}}" placeholder="Search any data...">
        <button type="submit">Search</button>
        <a href="/table/{{tableName}}"><button type="button">Clear</button></a>
    </form>

    <table border="1" width="100%" style="border-collapse: collapse;">
        <tr style="background: #eee;">
            {{#each columns}} <th>{{this}}</th> {{/each}}
        </tr>
        {{#each rows}}
            <tr>
                {{#each ../columns}} <td>{{lookup .. this}}</td> {{/each}}
            </tr>
        {{/each}}
    </table>

    <div style="margin-top: 20px;">
        {{#if prevPage}}
            <a href="/table/{{tableName}}?page={{prevPage}}&search={{search}}"><button>&larr; Previous Page</button></a>
        {{/if}}
        <span style="margin: 0 15px;">Page {{page}}</span>
        <a href="/table/{{tableName}}?page={{nextPage}}&search={{search}}"><button>Next Page &rarr;</button></a>
    </div>
</div>